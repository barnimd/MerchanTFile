@model MerchantFile.Models.GenerateJobViewModel
@{
    ViewBag.Title = "New job";
    var steps = new[] {
        new { Label = "Template", Desc = "PDF or Word" },
        new { Label = "Data",     Desc = "Excel file" },
        new { Label = "Preview",  Desc = "Check pages" },
        new { Label = "Download", Desc = "Save PDF" }
    };
}

<!-- Stepper -->
<div class="mf-stepper-wrap">
    <div class="mf-stepper">
        @for (var i = 0; i < steps.Length; i++)
        {
            var idx = i + 1;
            var done = idx < Model.Step;
            var active = idx == Model.Step;
            var cls = done ? "mf-step-node--done" : active ? "mf-step-node--active" : "";
            <div class="mf-step-node @cls">
                <div class="mf-step-circle">
                    @if (done)
                    {
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="4 12 10 18 20 6" />
                        </svg>
                    }
                    else
                    {
                        @idx
                    }
                </div>
                <div class="mf-step-label">
                    <div class="mf-step-label-main">@steps[i].Label</div>
                    <div class="mf-step-label-sub">@steps[i].Desc</div>
                </div>
            </div>
            if (i < steps.Length - 1)
            {
                var conDone = idx < Model.Step;
                <div class="mf-step-connector @(conDone ? "mf-step-connector--done" : "")"></div>
            }
        }
    </div>
</div>

<!-- Step body -->
<div class="mf-wizard-body">
    <div class="mf-wizard-inner">
        @switch (Model.Step)
        {
            case 1:
                @Html.Partial("_StepTemplate", Model)
                break;
            case 2:
                @Html.Partial("_StepData", Model)
                break;
            case 3:
                @Html.Partial("_StepPreview", Model)
                break;
            case 4:
                @Html.Partial("_StepDone", Model)
                break;
        }
    </div>
</div>

@section scripts {
    <script>
        (function ($) {
            // Drop-zone interactions: visual hover + auto-submit on pick / drop.
            $('.mf-dropzone').on('dragover dragenter', function (e) {
                e.preventDefault();
                $(this).addClass('mf-dropzone--hover');
            }).on('dragleave', function (e) {
                e.preventDefault();
                $(this).removeClass('mf-dropzone--hover');
            }).on('drop', function (e) {
                e.preventDefault();
                $(this).removeClass('mf-dropzone--hover');
                var files = e.originalEvent.dataTransfer && e.originalEvent.dataTransfer.files;
                if (!files || !files.length) return;
                var $input = $(this).find('input[type=file]');
                if (!$input.length) return;
                // Assign to the input and submit. DataTransfer trick to set FileList.
                var dt = new DataTransfer();
                dt.items.add(files[0]);
                $input[0].files = dt.files;
                $input.trigger('change');
            });

            $('.mf-dropzone input[type=file]').on('change', function () {
                var $form = $(this).closest('form');
                if (!$form.length) return;
                // Submit FIRST — replacing the dropzone HTML before submit would
                // detach the file input and send an empty multipart body.
                $form.trigger('submit');
                var $zone = $(this).closest('.mf-dropzone');
                $zone.css('opacity', 0.5).find('.mf-dropzone-title').text('Uploading…');
            });

            // Preview arrow-key navigation when the preview pane is visible.
            $(document).on('keydown', function (e) {
                if (!$('.mf-preview-grid').length) return;
                if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA')) return;
                if (e.key === 'ArrowLeft') {
                    var $p = $('.mf-prev-btn');
                    if ($p.length) { window.location.href = $p.attr('href'); }
                } else if (e.key === 'ArrowRight') {
                    var $n = $('.mf-next-btn');
                    if ($n.length) { window.location.href = $n.attr('href'); }
                }
            });

            // Step 4: auto-trigger download once on first arrival.
            @if (Model.Step == 4)
            {
                <text>
                if (!sessionStorage.getItem('mf-dl-@Model.JobId')) {
                    sessionStorage.setItem('mf-dl-@Model.JobId', '1');
                    setTimeout(function () {
                        window.location.href = '@Url.Action("Download", "Generate", new { jobId = Model.JobId })';
                    }, 350);
                }
                </text>
            }
        })(jQuery);
    </script>
}

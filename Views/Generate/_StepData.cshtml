@model MerchantFile.Models.GenerateJobViewModel

<div class="mf-step-header">
    <h2 class="mf-h2">Upload your Excel data</h2>
    <p>Each row generates one PDF page. We'll match column names to template placeholders.</p>
</div>

@if (TempData["WizardError"] != null)
{
    <div class="mf-info-banner" style="background:var(--mf-danger-soft);border-color:#FCA5A5;color:var(--mf-danger-fg);margin-bottom:16px;">
        <span class="mf-info-banner-icon" style="color:var(--mf-danger);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
        </span>
        <div>@TempData["WizardError"]</div>
    </div>
}

<div class="mf-wizard-card">
    @if (!Model.DataUploaded)
    {
        using (Html.BeginForm("UploadExcel", "Generate", FormMethod.Post, new { enctype = "multipart/form-data", id = "dataForm" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="jobId" value="@Model.JobId" />
            <label class="mf-dropzone" tabindex="0" for="dataFile">
                <span class="mf-dropzone-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
                        <path d="M14 3v5h5" />
                        <path d="M9 13l2 3 2-3M9 19l2-3 2 3" />
                    </svg>
                </span>
                <div>
                    <div class="mf-dropzone-title">Drop your spreadsheet here</div>
                    <div class="mf-dropzone-sub">.xlsx or .xls &mdash; up to 10 MB</div>
                </div>
                <span class="mf-btn mf-btn-secondary" style="pointer-events:none;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <path d="M17 8l-5-5-5 5" />
                        <path d="M12 3v12" />
                    </svg>
                    Browse files
                </span>
                <input type="file" id="dataFile" name="file" accept=".xlsx,.xls" style="display:none;" />
            </label>
        }
    }
    else
    {
        <div class="mf-filepill">
            <span class="mf-filepill-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
                    <path d="M14 3v5h5" />
                    <path d="M9 13l2 3 2-3M9 19l2-3 2 3" />
                </svg>
            </span>
            <div class="mf-filepill-main">
                <div class="mf-filepill-name">@Model.Meta.DataFileName</div>
                <div class="mf-filepill-meta">@Model.DataMeta</div>
            </div>
            <span class="mf-badge mf-badge--success">Uploaded</span>
            <a href="@Url.Action("Wizard", "Generate", new { step = 2, jobId = Model.JobId, reset = "data" })" class="mf-filepill-remove" title="Remove">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                    <path d="M10 11v6M14 11v6" />
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                </svg>
            </a>
        </div>

        @{
            var totalRows = Model.Rows.Count;
            var errCount = Model.Meta.ErrorRowCount;
        }
        <div style="margin-top:18px;">
            <div class="mf-data-head">
                <span class="mf-caption">Data preview</span>
                @if (errCount > 0)
                {
                    <span class="mf-badge mf-badge--failed">@errCount error@(errCount == 1 ? "" : "s") in @totalRows rows</span>
                }
                else
                {
                    <span class="mf-badge mf-badge--success">All @totalRows row@(totalRows == 1 ? "" : "s") valid</span>
                }
            </div>
            <div class="mf-data-wrap">
                <table class="mf-data-table">
                    <thead>
                        <tr>
                            <th class="mf-th-num">#</th>
                            <th>Full Name <span class="mf-mapping-pill">&rarr; {{name}}</span></th>
                            <th>NIK <span class="mf-mapping-pill">&rarr; {{nik}}</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Rows)
                        {
                            <tr class="@(r.IsValid ? "" : "mf-row-error")" title="@(r.IsValid ? "" : string.Join(" · ", r.Errors))">
                                <td class="mf-td-num">@r.RowNumber</td>
                                <td class="mf-td-name">@r.FullName</td>
                                <td class="mf-td-nik">@r.Nik</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<div class="mf-wizard-footer">
    <a href="@Url.Action("Wizard", "Generate", new { step = 1, jobId = Model.JobId })" class="mf-btn mf-btn-secondary mf-btn-lg">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <line x1="20" y1="12" x2="4" y2="12" />
            <polyline points="10 18 4 12 10 6" />
        </svg>
        Back
    </a>
    @{
        var canContinue = Model.DataUploaded && Model.Meta.ErrorRowCount == 0 && Model.Rows.Count > 0;
    }
    <a href="@Url.Action("Wizard", "Generate", new { step = 3, jobId = Model.JobId })"
       class="mf-btn mf-btn-primary mf-btn-lg @(canContinue ? "" : "disabled")"
       aria-disabled="@(canContinue ? "false" : "true")">
        Generate preview
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="12" x2="20" y2="12" />
            <polyline points="14 6 20 12 14 18" />
        </svg>
    </a>
</div>
